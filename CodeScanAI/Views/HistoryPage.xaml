<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CodeScanAI.ViewModels"
             x:Class="CodeScanAI.Views.HistoryPage"
             Title="Historial">

    <CollectionView ItemsSource="{Binding Items}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems>
                            <SwipeItem Text="Eliminar"
                                       BackgroundColor="Red"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteCommand}"
                                       CommandParameter="{Binding .}"/>
                        </SwipeItems>
                    </SwipeView.RightItems>
                    <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="{Binding AnalysisType}" FontAttributes="Bold" FontSize="14"/>
                            <Label Text="{Binding CodeSnippet}" FontSize="12" TextColor="Gray"
                                   LineBreakMode="TailTruncation" MaxLines="2"/>
                            <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="11" TextColor="LightGray"/>
                        </VerticalStackLayout>
                    </Grid>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>